# === Database ===
# Path to KBOB Ökobilanzdaten SQLite database
KBOB_DATABASE_PATH=./Oekobilanzdaten.sqlite3

# === SBERT Runtime ===
# Force device: cpu or cuda (auto-detected if unset)
# SBERT_DEVICE=cpu
# Fixed batch size (overrides heuristic)
# SBERT_BATCH_SIZE=64
# Enable batch benchmark before matching
# SBERT_AUTO_BENCH_BATCH=0
# Enable heuristic batch sizing (default: on)
# SBERT_AUTO_HEURISTIC_BATCH=1
# Minimum queries before auto-switching to CUDA
# SBERT_CUDA_QUERY_THRESHOLD=500

# === Cross-Encoder ===
# Pin a specific model revision for reproducibility
# SBERT_CROSS_ENCODER_REVISION=
# Allow remote code updates for cross-encoder models
# SBERT_CROSS_ENCODER_ALLOW_UPDATES=0
